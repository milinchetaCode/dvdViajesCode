<%- include('partials/header') %>

<!-- HERO -->
<section class="relative mb-12 bg-gradient-to-r from-white to-brand/5">
  <div class="px-6 py-12 md:py-20">
    <div class="max-w-6xl mx-auto text-center">
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-4 tracking-tight text-brand leading-snug">
        Viví el deporte en vivo
      </h2>
      <div class="w-16 h-1 mx-auto bg-accent rounded mt-2 mb-6"></div>
    </div>

    <!-- Banner -->
    <div class="relative w-full flex justify-center">
      <div class="relative w-full sm:w-4/5 md:w-3/4 lg:w-3/4">
        <a href="/f1" class="block relative overflow-hidden rounded-2xl transition-transform transform hover:scale-[1.02]">
          <img src="/images/f1.jpeg" alt="Fórmula 1" class="w-full h-80 object-cover rounded-2xl" />
          <div class="absolute inset-0 bg-black/40 flex flex-col justify-center items-center text-center text-white px-4">
            <h3 class="text-4xl sm:text-5xl font-extrabold mb-4">Fórmula 1</h3>
            <span
              class="inline-block text-lg font-semibold text-white bg-accent px-6 py-3 rounded-full shadow-md 
                     hover:bg-accent/90 hover:scale-[1.04] transform transition-all duration-300">
              Encontrá tu entrada
            </span>
          </div>
        </a>
      </div>
    </div>
  </div>
</section>

<!-- Paquetes turísticos -->
<div class="px-4 md:px-6 lg:px-8">
  <section class="mb-12">
    <div class="text-center mb-8">
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold flex items-center justify-center gap-2 text-brand">
        <i data-feather="package" class="w-6 h-6 text-accent"></i>
        Paquetes turísticos
      </h2>
      <div class="w-16 h-1 mx-auto bg-accent rounded mt-2 mb-6"></div>
    </div>

    <% if (packages && packages.length) { %>
      <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <% packages.filter(pkg => pkg.visible).forEach(pkg => { %>
          <li class="bg-white p-6 rounded-2xl border border-gray-200 shadow-md transition-all duration-300 hover:shadow-xl">
            <img 
              src="<%= pkg.photoUrl && pkg.photoUrl.trim() !== '' ? pkg.photoUrl.trim() : (pkg.foto && pkg.foto.trim() !== '' ? '/images/' + pkg.foto.trim() + '.jpeg' : '/images/default.jpeg') %>"
              alt="<%= pkg.eventName %>"
              class="w-full h-44 object-cover rounded-2xl border border-gray-200 mb-4"
            />
            <span class="inline-block text-xs bg-accent/20 text-brand font-semibold px-2 py-1 rounded-full mb-2">
              Paquete
            </span>
            <h3 class="text-xl font-bold tracking-tight text-gray-900 mb-2">
              <a href="/paquete/<%= pkg.id %>" class="hover:text-accent transition-colors">
                <%= pkg.eventName %>
              </a>
            </h3>
            <p class="text-sm text-gray-700 mb-1"><strong>📅 Fechas:</strong> <%= pkg.availabilityDates %></p>
            <p class="text-lg font-bold text-accent mt-3">
              <% if (pkg.ticketPrice) { %>
                💶 u$d <%= pkg.ticketPrice.toLocaleString('es-ES') %>
              <% } else { %>
                Precio no disponible
              <% } %>
            </p>
            <a href="/paquete/<%= pkg.id %>" 
               class="inline-block mt-3 text-sm text-white bg-brand rounded-lg px-4 py-2 font-semibold hover:bg-brand/90 transition-colors">
              Ver detalles
            </a>
          </li>
        <% }) %>
      </ul>
    <% } else { %>
      <p class="text-center text-gray-600">No hay paquetes disponibles en este momento.</p>
    <% } %>
  </section>
</div>

<%- include('partials/footer') %>
