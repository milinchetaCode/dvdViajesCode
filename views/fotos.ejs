<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Galería Admin - QualyTours</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    /* Buttons */
    button {
      @apply transition-all duration-300 ease-in-out;
    }
    button:hover {
      @apply shadow-lg;
    }

    /* Image Cards */
    .image-card {
      @apply bg-white rounded-lg shadow-md p-3 flex flex-col items-center transition-transform duration-200 hover:scale-105;
    }
    .image-card img {
      @apply max-w-full h-40 object-cover rounded-lg mb-2;
    }
    .image-card p {
      @apply text-gray-700 text-xs break-all truncate;
    }

    /* Gallery Section */
    .gallery-section {
      @apply bg-gray-50 p-6 rounded-lg shadow-md;
    }

    /* Tabs */
    .tab-button {
      @apply px-4 py-2 font-semibold rounded-t-lg cursor-pointer border-b-2 border-transparent;
    }
    .tab-button.active {
      @apply border-green-700 text-green-700;
    }

    /* Fade-in animation */
    .fade-in {
      @apply opacity-0 transform translate-y-4 transition-all duration-700;
    }
    .fade-in.visible {
      @apply opacity-100 translate-y-0;
    }

    /* Upload Form */
    .upload-form {
      @apply flex flex-col md:flex-row items-start md:items-center gap-4 mb-4;
    }

    /* Always show upload button */
    .upload-btn-wrapper {
      @apply sticky top-4 z-10;
    }
  </style>
</head>
<body class="bg-gray-100 min-h-screen p-6 font-sans">

  <!-- Header -->
  <header class="flex justify-between items-center mb-6 bg-white shadow-md rounded-lg p-4">
    <h1 class="text-2xl font-bold text-green-800">Galería Admin - QualyTours</h1>
    <div class="flex space-x-2">
      <a href="/admin/panel" class="bg-gray-500 hover:bg-gray-600 text-white px-4 py-2 rounded shadow-lg">Volver al Panel</a>
      <a href="/admin/logout" class="text-red-600 hover:underline self-center">Cerrar sesión</a>
    </div>
  </header>

  <!-- Tabs -->
  <div class="mb-6 flex space-x-4 border-b-2 border-gray-200">
    <button class="tab-button active" data-tab="paquetes">Fotos Paquetes</button>
    <button class="tab-button" data-tab="slider">Fotos Slider</button>
  </div>

  <!-- Tab Contents -->
  <div id="tab-paquetes" class="tab-content">
    <div class="gallery-section">
      <h2 class="text-xl font-semibold mb-4 text-green-800">Fotos Paquetes</h2>

      <!-- Upload Section -->
      <div class="upload-btn-wrapper">
        <form action="/admin/photos/upload" method="POST" enctype="multipart/form-data" class="upload-form">
          <input type="hidden" name="folder" value="ManuFigueroaViajes/Packs">
          <input type="file" name="image" required class="border p-2 rounded">
          <button type="submit" class="bg-green-700 hover:bg-green-800 text-white px-4 py-2 rounded shadow-lg">Subir</button>
          <p class="text-sm text-gray-600 mt-2 md:mt-0">Luego de subir la foto esperar unos segundos y refrescar la página.</p>
        </form>
      </div>

      <!-- Image Grid -->
      <div class="grid gap-4 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
        <% if (paquetesImages && paquetesImages.length) { %>
          <% paquetesImages.forEach((img) => { %>
            <div class="image-card fade-in">
              <img src="<%= img.secure_url %>" alt="<%= img.public_id %>">
              <p><%= img.secure_url %></p>
              <div class="flex space-x-2 mt-2">
                <button type="button" onclick="navigator.clipboard.writeText('<%= img.secure_url %>')" class="bg-green-700 hover:bg-green-800 text-white px-2 py-1 rounded text-sm">Copiar URL</button>
                <form action="/admin/photos/delete" method="POST">
                  <input type="hidden" name="public_id" value="<%= img.public_id %>">
                  <button type="submit" class="bg-red-600 hover:bg-red-500 text-white px-2 py-1 rounded text-sm">Eliminar</button>
                </form>
              </div>
            </div>
          <% }) %>
        <% } else { %>
          <p class="text-gray-600">No hay fotos en esta carpeta.</p>
        <% } %>
      </div>
    </div>
  </div>

  <div id="tab-slider" class="tab-content hidden">
    <div class="gallery-section">
      <h2 class="text-xl font-semibold mb-4 text-green-800">Fotos Slider</h2>

      <!-- Upload Section -->
      <div class="upload-btn-wrapper">
        <form action="/admin/photos/upload" method="POST" enctype="multipart/form-data" class="upload-form">
          <input type="hidden" name="folder" value="ManuFigueroaViajes/HeroSlider">
          <input type="file" name="image" required class="border p-2 rounded">
          <button type="submit" class="bg-green-700 hover:bg-green-800 text-white px-4 py-2 rounded shadow-lg">Subir</button>
          <p class="text-sm text-gray-600 mt-2 md:mt-0">Luego de subir la foto esperar unos segundos y refrescar la página.</p>
        </form>
      </div>

      <!-- Image Grid -->
      <div class="grid gap-4 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
        <% if (sliderImages && sliderImages.length) { %>
          <% sliderImages.forEach((img) => { %>
            <div class="image-card fade-in">
              <img src="<%= img.secure_url %>" alt="<%= img.public_id %>">
              <p><%= img.secure_url %></p>
              <div class="flex space-x-2 mt-2">
                <button type="button" onclick="navigator.clipboard.writeText('<%= img.secure_url %>')" class="bg-green-700 hover:bg-green-800 text-white px-2 py-1 rounded text-sm">Copiar URL</button>
                <form action="/admin/photos/delete" method="POST">
                  <input type="hidden" name="public_id" value="<%= img.public_id %>">
                  <button type="submit" class="bg-red-600 hover:bg-red-500 text-white px-2 py-1 rounded text-sm">Eliminar</button>
                </form>
              </div>
            </div>
          <% }) %>
        <% } else { %>
          <p class="text-gray-600">No hay fotos en esta carpeta.</p>
        <% } %>
      </div>
    </div>
  </div>

  <script>
    // Tabs
    const tabButtons = document.querySelectorAll('.tab-button');
    const tabContents = document.querySelectorAll('.tab-content');

    tabButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        tabButtons.forEach(b => b.classList.remove('active'));
        tabContents.forEach(tc => tc.classList.add('hidden'));
        btn.classList.add('active');
        document.getElementById('tab-' + btn.dataset.tab).classList.remove('hidden');
      });
    });

    // Fade-in animation
    window.addEventListener('DOMContentLoaded', () => {
      const cards = document.querySelectorAll('.fade-in');
      cards.forEach((card, index) => {
        setTimeout(() => card.classList.add('visible'), index * 100);
      });
    });
  </script>

</body>
</html>
